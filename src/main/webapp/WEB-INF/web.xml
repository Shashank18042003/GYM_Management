    <servlet>
        <servlet-name>UpdateProfile</servlet-name>
        <servlet-class>com.gym.servlet.UpdateProfile</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProfile</servlet-name>
        <url-pattern>/UpdateProfile</url-pattern>
    </servlet-mapping>

</web-app>