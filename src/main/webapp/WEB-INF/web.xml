        <servlet-name>Register</servlet-name>
        <url-pattern>/Register</url-pattern>
    </servlet-mapping>

    <!-- FETCH -->
    <servlet>
        <servlet-name>Fetch</servlet-name>
        <servlet-class>com.gym.servlet.Fetch</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Fetch</servlet-name>
        <url-pattern>/Fetch</url-pattern>
    </servlet-mapping>

    <!-- ADMIN DASHBOARD -->
    <servlet>
        <servlet-name>Admindashboard</servlet-name>
        <servlet-class>com.gym.servlet.Admindashboard</servlet-class>
