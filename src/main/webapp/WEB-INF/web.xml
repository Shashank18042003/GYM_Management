    <servlet>
        <servlet-name>Delete</servlet-name>
        <servlet-class>com.gym.servlet.Delete</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Delete</servlet-name>
        <url-pattern>/Delete</url-pattern>
    </servlet-mapping>

    <!-- LOGOUT -->
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>com.gym.servlet.Logout</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>

