    <servlet>
        <servlet-name>AddEvent</servlet-name>
        <servlet-class>com.gym.servlet.AddEvent</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddEvent</servlet-name>
        <url-pattern>/AddEvent</url-pattern>
    </servlet-mapping>

